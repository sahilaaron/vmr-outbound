# VMR Outbound Agent — environment variable reference.
#
# Copy to `.env` for local development and fill in local values only.
# NEVER commit a real `.env` or any credential. Production/staging values are
# supplied by the deployment environment or a secret manager, not this file.

# --- Application ---
APP_NAME="VMR Outbound Agent"
# local | ci | staging | production
APP_ENV=local
DEBUG=false

# --- Safety switches ---
# Dry-run defaults to true. Only a deliberate, reviewed change may set it false,
# and only in an environment authorized to schedule real email.
DRY_RUN=true

# --- Database ---
# Active database mode (FND-009): "local" (default, loopback Postgres) or
# "rds-dev" (the development RDS instance). Each mode fails closed when its
# rules are not met — local requires a loopback host; rds-dev requires an
# explicit DATABASE_URL pointing at a non-loopback host WITH a strong sslmode
# (require / verify-ca / verify-full). Local-only tooling (dev_up, workbench
# reset/fixtures, pytest, alembic downgrade) always refuses rds-dev.
DATABASE_TARGET=local
# SQLAlchemy URL. Local dev default matches docs/DEVELOPMENT.md.
# The rds-dev/production value is a SECRET supplied only through this local
# file or a secret manager — never committed, logged, or pasted anywhere.
# rds-dev shape (placeholders only — see docs/DEVELOPMENT.md):
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ENDPOINT:5432/DBNAME?sslmode=verify-full&sslrootcert=C:/path/to/rds-global-bundle.pem
DATABASE_URL=postgresql+psycopg://dev@127.0.0.1:5433/vmr_dev

# --- Database pool & timeout behaviour (FND-009; defaults are conservative) ---
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=5
# DB_POOL_TIMEOUT_SECONDS=30
# DB_POOL_RECYCLE_SECONDS=1800
# DB_CONNECT_TIMEOUT_SECONDS=10
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_LOCK_TIMEOUT_MS=5000
# DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=60000

# --- Operator workbench (local) ---
# Server-rendered local UI. Both stay off by default; enable together for
# local operation (see docs/WORKBENCH.md).
# FEATURES__WORKBENCH=false
# Staged uploads for the preview -> confirm import flow live on local disk:
# STAGED_UPLOADS_DIR=var/staged_uploads
# Maximum spreadsheet upload size in bytes; oversized files are rejected
# before parsing or staging. Default 26214400 (25 MB).
# MAX_UPLOAD_BYTES=26214400

# --- Sales Navigator capture intake (DAT-009, local only) ---
# Loopback base URL used to build the operator workbench deep link returned to
# the capture extension. Must be a loopback origin.
# OPERATOR_BASE_URL=http://127.0.0.1:8000
# Maximum Sales Navigator intake body size in bytes; oversized bodies are
# rejected with 413 before parsing. Default 2097152 (2 MB).
# SALESNAV_INTAKE_MAX_BYTES=2097152
# Wall-clock budget in seconds for one intake staging operation; on breach the
# staging transaction rolls back and the request returns 504. Default 15.
# SALESNAV_INTAKE_TIMEOUT_SECONDS=15

# --- Sales Navigator company-domain enrichment (DAT-010, local only) ---
# Off by default. When on, the operator can look up a captured company's domain
# through the official logo.dev Search Brands API and confirm one candidate by
# hand. Nothing is auto-accepted and no domain is invented.
# FEATURES__SALESNAV_DOMAIN_ENRICHMENT=false
# logo.dev Search Brands by Name API key (SECRET). Provide a local value only;
# never commit a real key. When unset, the lookup reports "API not configured".
# LOGO_DEV_API_KEY=
# Optional overrides (defaults are fine for local use):
# LOGO_DEV_SEARCH_URL=https://api.logo.dev/search
# LOGO_DEV_TIMEOUT_SECONDS=10
# LOGO_DEV_MAX_CANDIDATES=10

# --- Feature switches (all default off; enable per phase as built) ---
# FEATURES__CSV_IMPORT=false
# Local Sales Navigator capture intake endpoint (DAT-009). Off by default.
# FEATURES__SALESNAV_INTAKE=false
# FEATURES__NORMALIZATION=false
# FEATURES__DEDUPLICATION=false
# FEATURES__SUPPRESSIONS=false
# FEATURES__EMAIL_GENERATION=false
# FEATURES__MILLIONVERIFIER=false
# FEATURES__SCORING=false
# FEATURES__INSIGHTS_RESEARCH=false
# FEATURES__CLAUDE_MCP_BRIDGE=false
# FEATURES__DRAFTING=false
# FEATURES__SALESHANDY=false

# --- External providers (names only; NO keys committed) ---
# Populate these in the deployment secret manager when their phase is built.
# MILLIONVERIFIER_API_KEY=
# SALESHANDY_API_KEY=
