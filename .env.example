# VMR Outbound Agent — environment variable reference.
#
# Copy to `.env` for local development and fill in local values only.
# NEVER commit a real `.env` or any credential. Production/staging values are
# supplied by the deployment environment or a secret manager, not this file.

# --- Application ---
APP_NAME="VMR Outbound Agent"
# local | ci | staging | production
APP_ENV=local
DEBUG=false

# --- Safety switches ---
# Dry-run defaults to true. Only a deliberate, reviewed change may set it false,
# and only in an environment authorized to schedule real email.
DRY_RUN=true

# --- Database ---
# SQLAlchemy URL. Local dev default matches docs/DEVELOPMENT.md.
# Production uses the same variable name, populated from the RDS secret — the
# value below is a non-secret local default and must be overridden in RDS envs.
DATABASE_URL=postgresql+psycopg://dev@127.0.0.1:5433/vmr_dev

# --- Operator workbench (local) ---
# Server-rendered local UI. Both stay off by default; enable together for
# local operation (see docs/WORKBENCH.md).
# FEATURES__WORKBENCH=false
# Staged uploads for the preview -> confirm import flow live on local disk:
# STAGED_UPLOADS_DIR=var/staged_uploads
# Maximum spreadsheet upload size in bytes; oversized files are rejected
# before parsing or staging. Default 26214400 (25 MB).
# MAX_UPLOAD_BYTES=26214400

# --- Sales Navigator capture intake (DAT-009, local only) ---
# Loopback base URL used to build the operator workbench deep link returned to
# the capture extension. Must be a loopback origin.
# OPERATOR_BASE_URL=http://127.0.0.1:8000
# Maximum Sales Navigator intake body size in bytes; oversized bodies are
# rejected with 413 before parsing. Default 2097152 (2 MB).
# SALESNAV_INTAKE_MAX_BYTES=2097152

# --- Feature switches (all default off; enable per phase as built) ---
# FEATURES__CSV_IMPORT=false
# Local Sales Navigator capture intake endpoint (DAT-009). Off by default.
# FEATURES__SALESNAV_INTAKE=false
# FEATURES__NORMALIZATION=false
# FEATURES__DEDUPLICATION=false
# FEATURES__SUPPRESSIONS=false
# FEATURES__EMAIL_GENERATION=false
# FEATURES__MILLIONVERIFIER=false
# FEATURES__SCORING=false
# FEATURES__INSIGHTS_RESEARCH=false
# FEATURES__CLAUDE_MCP_BRIDGE=false
# FEATURES__DRAFTING=false
# FEATURES__SALESHANDY=false

# --- External providers (names only; NO keys committed) ---
# Populate these in the deployment secret manager when their phase is built.
# MILLIONVERIFIER_API_KEY=
# SALESHANDY_API_KEY=
